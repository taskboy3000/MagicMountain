#!/usr/bin/env perl
use strict;
use warnings;
use Mojo::JSON qw(decode_json);

my $file = shift or die "Usage: $0 <transcript.jsonl>\n";
open my $fh, '<', $file or die "Cannot open $file: $!";

# Read first line for bot roster
my $first = <$fh>;
my $start = decode_json($first);

my (%cid, %n2b);
if ($start->{bots}) {
    for my $b (@{$start->{bots}}) { $cid{$b->{char_id}} = $b; $n2b{$b->{name}} = $b; }
}

my %stats;
my %bot_score;
my $run_id = $start->{run_id};

$stats{bot_count} = $start->{bot_count} // 0;
$stats{sim_days}  = $start->{days} // 0;

    # Per-bot tracking
my (%cnt, %scr, %off);

while (my $line = <$fh>) {
    chomp $line;
    my $ev = decode_json($line);

    $stats{total_events}++;

    if ($ev->{type} eq 'artifact_start') {
        $stats{artifacts}++;
        $stats{artifacts_per_bot}{$ev->{char_id}}++;
    }
    elsif ($ev->{type} eq 'push') {
        $stats{pushes}++;
        $stats{stage}{$ev->{stage}}++;
    }
    elsif ($ev->{type} eq 'collapse') {
        $stats{collapses}++;
    }
    elsif ($ev->{type} eq 'breakthrough') {
        $stats{breakthroughs}++;
    }
    elsif ($ev->{type} eq 'stop') {
        $stats{stops}++;
    }
    elsif ($ev->{type} eq 'sale') {
        $stats{sales}++;
        $stats{total_sale_value} += $ev->{value};
        $bot_score{$ev->{char_id}} += $ev->{value};
    }

    # Per-bot tracking
    my $bot;
    if ($ev->{char_id} && $cid{$ev->{char_id}}) { $bot = $cid{$ev->{char_id}}; }
    elsif ($ev->{player} && $n2b{$ev->{player}}) { $bot = $n2b{$ev->{player}}; }
    next unless $bot;
    $cnt{$bot->{name}}{$ev->{type}}++;
    $scr{$bot->{name}} = ($scr{$bot->{name}} // 0) + ($ev->{value} // 0) if $ev->{type} eq "sale";
    if ($ev->{type} eq "offer") {
        $off{$bot->{name}}{total}++;
        $off{$bot->{name}}{match}++ if $ev->{match};
    }
}

close $fh;

# --- Aggregate stats ---
my $total = ($stats{collapses} // 0) + ($stats{stops} // 0) + ($stats{breakthroughs} // 0);
$total ||= 1;

printf "=== Simulation Analysis ===\n";
printf "Run:        %s\n", $run_id // 'unknown';
printf "Bots:       %d\n", $stats{bot_count} // 0;
printf "Days:       %d\n", $stats{sim_days} // 0;
printf "Artifacts:  %d\n", $stats{artifacts} // 0;
printf "Pushes:     %d\n", $stats{pushes} // 0;
printf "Collapses:  %d (%.1f%%)\n", $stats{collapses} // 0, 100 * ($stats{collapses} // 0) / $total;
printf "Breakthroughs: %d (%.1f%%)\n", $stats{breakthroughs} // 0, 100 * ($stats{breakthroughs} // 0) / $total;
printf "Stops:      %d (%.1f%%)\n", $stats{stops} // 0, 100 * ($stats{stops} // 0) / $total;
printf "Sales:      %d\n", $stats{sales} // 0;
printf "Avg sale:   %.1f\n", $stats{sales} ? ($stats{total_sale_value} // 0) / $stats{sales} : 0;
printf "Avg pushes per artifact: %.1f\n", $stats{artifacts} ? ($stats{pushes} // 0) / $stats{artifacts} : 0;

if (keys %bot_score) {
    my @scores = sort { $a <=> $b } values %bot_score;
    printf "Score range: %d - %d\n", $scores[0], $scores[-1];
    my $sum; $sum += $_ for values %bot_score;
    printf "Avg score:   %.1f\n", $sum / scalar(keys %bot_score);
}

# --- Per-bot table ---
if (keys %cnt) {
    print "\n";
    printf "%-22s | %-16s | %-16s | Score | Sls | Sell%%\n", "Bot", "Push", "Sell";
    print "-" x 80 . "\n";
    for my $n (sort keys %cnt) {
        my $b = $n2b{$n};
        my $total_offers = $off{$n}{total} // 0;
        my $match_pct = $total_offers ? int(($off{$n}{match}//0) / $total_offers * 100) : 0;
        printf "%-22s | %-16s | %-16s | %4d  | %2d  | %3d%%\n",
            $n, $b->{push_policy}, $b->{sell_policy}, $scr{$n} // 0,
            $cnt{$n}{sale} // 0, $match_pct;
    }
}

# --- By sell policy ---
if (keys %scr) {
    print "\n=== BY SELL POLICY ===\n";
    my (%sp_sc, %sp_ct, %sp_sl, %sp_of, %sp_mt);
    for my $n (keys %scr) {
        my $sp = $n2b{$n}{sell_policy};
        $sp_sc{$sp} += $scr{$n}; $sp_ct{$sp}++; $sp_sl{$sp} += $cnt{$n}{sale};
        $sp_of{$sp} += $off{$n}{total} // 0; $sp_mt{$sp} += $off{$n}{match} // 0;
    }
    printf "%-18s | Score  | Sales | Match%%\n", "Sell Policy";
    print "-" x 50 . "\n";
    for my $sp (sort { ($sp_sc{$b}//0) <=> ($sp_sc{$a}//0) } keys %sp_sc) {
        my $n = $sp_ct{$sp} || 1;
        my $m = $sp_mt{$sp} // 0; my $t = $sp_of{$sp} // 0;
        printf "%-18s | %4d   | %4.1f  | %d%%\n",
            $sp, int($sp_sc{$sp}/$n), $sp_sl{$sp}/$n, $t ? int($m/$t*100) : 0;
    }

    # --- By push policy ---
    print "\n=== BY PUSH POLICY ===\n";
    my (%pp_sc, %pp_ct);
    for my $n (keys %scr) {
        my $pp = $n2b{$n}{push_policy};
        $pp_sc{$pp} += $scr{$n}; $pp_ct{$pp}++;
    }
    for my $pp (sort { ($pp_sc{$b}//0) <=> ($pp_sc{$a}//0) } keys %pp_sc) {
        printf "%-18s | %4d\n", $pp, int($pp_sc{$pp}/$pp_ct{$pp});
    }
}
