#!/usr/bin/env perl
use v5.28;
use strict;
use warnings;
use File::Find;
use File::Spec;
use Cwd qw(abs_path);
use File::Basename qw(dirname);
use Mojo::DOM;

my $ROOT = File::Spec->catfile(dirname(abs_path($0)), '..');
chdir $ROOT;

my @templates;
find(sub { push @templates, $File::Find::name if /\.html\.ep$/ }, 'templates');

my $css_file = 'public/css/app.css';
my $css = do { local $/; open my $fh, '<', $css_file or die; <$fh> };

my $exit = 0;

sub report {
    my ($severity, $file, $line, $msg) = @_;
    print STDERR "$severity $file:$line $msg\n";
    $exit = 1 if $severity eq 'ERROR';
}

# ── Line number helper ──
sub _line_of {
    my ($content, $pos) = @_;
    return 1 unless defined $pos;
    return 1 + substr($content, 0, $pos) =~ tr/\n//;
}

# ── Strip .ep template directives, return clean HTML ~ preserving positions ──
sub _strip_ep {
    my ($raw) = @_;
    # Replace <% ... %> and <%= ... %> with spaces (preserve character positions)
    $raw =~ s/<%[=%]?.*?%>/' ' x length($&)/sge;
    # Remove leading % ... lines (perl control flow) — replace with newlines
    $raw =~ s/^%.*\n/\n/gm;
    # Also handle inline %> leftovers
    $raw =~ s/%>//g;
    return $raw;
}

# ── Extract CSS class names from app.css ──
(my $css_clean = $css) =~ s{/\*.*?\*/}{}gs;
my %css_classes;
{
    my $line_num = 0;
    for my $line (split /\n/, $css_clean) {
        $line_num++;
        while ($line =~ /\.([a-zA-Z][\w-]*)/g) {
            push @{$css_classes{$1}}, "public/css/app.css:$line_num";
        }
    }
}

# ── Scan templates ──
my (%used_classes, @inline_styles, @div_headings);

for my $tpl (@templates) {
    open my $fh, '<', $tpl or next;
    my $raw = do { local $/; <$fh> };
    close $fh;
    my $html = _strip_ep($raw);

    # Parse with Mojo::DOM
    my $dom = Mojo::DOM->new($html);

    # ── Inline styles via CSS selector ──
    $dom->find('[style]')->each(sub {
        my $el = shift;
        my $style = $el->attr('style') // return;
        $style =~ s/^\s+|\s+$//g;  # trim
        # Skip data-driven / dynamic styles
        return if $style =~ /<%=/;
        return if $style eq '' || $style eq 'cursor:pointer';
        return if $style =~ /^grid-(template-rows|row):/;
        return if $style =~ /^background:/;
        return if $style =~ /^display:(block|inline-flex);width:20px;height:2px/;
        return if $style eq 'flex:' || $style eq 'flex: ';
        return if $style =~ /^flex:\s*<%=/;
        # Skip whitelisted one-offs
        return if $style eq 'margin-right:4px';
        return if $style eq 'border-collapse:collapse';
        return if $style eq 'line-height:1.6';
        return if $style eq 'color:var(--mm-bg);background:var(--mm-text);font-size:0.72rem;padding:0.08rem 0.6rem;letter-spacing:0.1em;text-align:left';
        return if $style eq 'color:inherit;text-decoration:none;border-bottom:1px dotted rgba(255,255,255,0.15)';
        return if $style eq 'color:inherit;text-decoration:underline';
        return if $style eq 'text-transform:uppercase;letter-spacing:0.05em';
        return if $style eq 'letter-spacing:0.1em';
        return if $style =~ /^margin:(0 +)?0 +0 +0(\.\d+)?rem +0$/;
        return if $style eq 'flex:1' || $style eq 'flex:0.5';
        return if $style eq 'min-width:8rem;text-align:right';

        # Find line number by locating the style value in the raw template
        my $pos = index($raw, qq{style="$style"});
        # Fallback: search for the outer element's HTML
        if ($pos < 0) {
            my $outer = $el->to_string;
            $pos = index($raw, $outer);
        }
        my $line = _line_of($raw, $pos);
        push @inline_styles, { file => $tpl, line => $line, style => $style };
    });

    # ── Non-semantic headings via CSS selector ──
    $dom->find('div.mm-panel-header, div.mm-display-label')->each(sub {
        my $el = shift;
        my $class = $el->attr('class');
        my $pos = index($raw, qq{class="$class"});
        my $line = _line_of($raw, $pos);
        push @div_headings, "$tpl:$line";
    });

    # ── Class references (keep regex — class="..." is straightforward) ──
    while ($raw =~ /class="([^"]*)"/g) {
        for my $cls (split /\s+/, $1) {
            $used_classes{$cls} //= [];
            my $line = _line_of($raw, pos($raw) - length($&));
            push @{$used_classes{$cls}}, "$tpl:$line";
        }
    }
}

# ── Reports ──
print STDERR "\n=== CSS Style Check ===\n\n";

print STDERR "── Inline style= attributes (consider moving to classes) ──\n\n";
# Deduplicate: same file + line + style
my %seen;
@inline_styles = grep { !$seen{ "$_->{file}:$_->{line}:$_->{style}" }++ } @inline_styles;
if (@inline_styles) {
    for my $s (@inline_styles) {
        (my $short = $s->{file}) =~ s{^templates/}{};
        report 'STYLE', $short, $s->{line}, $s->{style};
    }
} else {
    print STDERR "  (none found)\n";
}

print STDERR "\n── Non-semantic headings (use h2-h5 instead) ──\n\n";
{
    my %dedup;
    @div_headings = grep { !$dedup{$_}++ } @div_headings;
}
if (@div_headings) {
    for my $h (@div_headings) {
        my ($file, $line) = $h =~ /^templates\/(.+?):(\d+)$/;
        report 'HEADING', $file, $line, 'div heading — use h2-h5';
    }
} else {
    print STDERR "  (none found)\n";
}

print STDERR "\n── Classes used in templates but not defined in CSS ──\n\n";
my @orphans;
for my $cls (sort keys %used_classes) {
    next if $cls eq '';
    next if $cls =~ /[\$\@\%<>]/;
    next if $cls eq "'unregistered'" || $cls eq "''";
    next if $cls =~ /^[^a-zA-Z]/;
    next if $css_classes{$cls};
    next if $cls eq 'nav-btn' || $cls eq 'active' || $cls eq 'current' || $cls eq 'inactive';
    next if $cls eq 'filled' || $cls eq 'danger' || $cls eq 'disabled';
    next if $cls =~ /^mm-badge-/;
    push @orphans, $cls;
}
if (@orphans) {
    for my $cls (@orphans) {
        my @loc = @{$used_classes{$cls}};
        my $loc_str = join(', ', map { (my $s = $_) =~ s{^templates/}{}; $s } @loc);
        report 'ORPHAN', $loc_str, '', "class \"$cls\" used but not defined in CSS";
    }
} else {
    print STDERR "  (none found)\n";
}

print STDERR "\n── CSS classes defined but never used in templates ──\n\n";
my @unused;
for my $cls (sort keys %css_classes) {
    next if $cls eq 'mm-badge' || $cls eq 'mm-meter-bar' || $cls eq 'mm-meter';
    next if $cls eq 'mm-status' || $cls eq 'mm-status-item' || $cls eq 'mm-status-label' || $cls eq 'mm-status-value';
    next if $cls eq 'mm-skeleton' || $cls eq 'mm-truncate';
    next if $cls eq 'mm-text-bright' || $cls eq 'mm-text-cyan' || $cls eq 'mm-text-bg';
    next if $cls eq 'text-center';
    next if $cls =~ /^mm-btn-/;
    next if $cls eq 'mm-system-dashboard-item';
    next if $cls eq 'unregistered';
    next if $cls eq 'mm-flex-1' || $cls eq 'mm-pre' || $cls eq 'mm-text-3xs';
    next if $cls eq 'mm-inline-flex' || $cls eq 'mm-flex-between' || $cls eq 'mm-flex-start';
    next if $cls eq 'mm-info-main' || $cls eq 'mm-info-aside';
    next if $cls eq 'offer-btn' || $cls eq 'buy-skill-btn';
    next if $cls eq 'cell-6x' || $cls eq 'cell-9x';
    next if $cls =~ /^mm-mountain-/;
    next if $cls eq 'mm-badge-red';
    next if $cls eq 'active' || $cls eq 'current' || $cls eq 'inactive';
    next if $cls eq 'filled' || $cls eq 'danger' || $cls eq 'disabled';
    next if $cls eq 'nav-btn';
    next if $used_classes{$cls};
    next if $cls eq 'text-rigth';
    push @unused, $cls;
}
if (@unused) {
    for my $cls (@unused) {
        my $loc = $css_classes{$cls}[0] // 'public/css/app.css';
        report 'UNUSED', $loc, '', "class \"$cls\" defined but never used in templates";
    }
} else {
    print STDERR "  (none found)\n";
}

print STDERR "\n── Typo check ──\n\n";
if ($css =~ /\.text-rigth\b/) {
    print STDERR "  INFO public/css/app.css: \".text-rigth\" is a deprecated alias for \".text-right\"\n";
} else {
    print STDERR "  (none found)\n";
}

print STDERR "\n";
exit $exit;
