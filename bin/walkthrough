#!/usr/bin/env perl
use v5.28;
use strict;
use warnings;
use Mojo::UserAgent;
use Mojo::DOM;
use Mojo::JSON qw(encode_json decode_json);
use Cwd qw(abs_path);
use File::Basename qw(dirname);
use File::Spec;
use File::Temp qw(tempdir);

my $PORT  = $ENV{MM_TEST_PORT} // 9900;
my $BASE  = "http://127.0.0.1:$PORT";
my $ROOT  = abs_path(File::Spec->catfile(dirname(__FILE__), '..'));

my $ua = Mojo::UserAgent->new;
my %COOKIE;
my $CSRF;

my $PASS = 0;
my $FAIL = 0;

sub assert($$) {
    my ($ok, $label) = @_;
    if ($ok) { $PASS++ }
    else     { $FAIL++; warn "  FAIL [$label]\n" }
}

sub dump_fail {
    my ($tx, $label) = @_;
    my $code = $tx->res->code // '???';
    my $body = $tx->res->body // '';
    $body = substr($body, 0, 500) . "..." if length $body > 500;
    warn "  FAIL [$label] HTTP $code\n  Body: $body\n";
    $FAIL++;
}

sub do_req {
    my ($method, $path, $body) = @_;
    my $url = "$BASE$path";
    my $tx = $ua->build_tx($method => $url);

    if ($method =~ /^(POST|PUT|DELETE|PATCH)$/ && $CSRF) {
        $tx->req->headers->header('X-CSRF-Token' => $CSRF);
    }
    if (defined $body) {
        $tx->req->headers->content_type('application/json');
        $tx->req->body(encode_json($body));
    }
    if (my @ck = map { "$_=$COOKIE{$_}" } keys %COOKIE) {
        $tx->req->headers->header(Cookie => join('; ', @ck));
    }

    $tx = $ua->start($tx);

    my $sc = $tx->res->headers->set_cookie;
    if ($sc) {
        for my $c (ref $sc eq 'ARRAY' ? @$sc : ($sc)) {
            if ($c =~ /^([^=]+)=([^;]+)/) { $COOKIE{$1} = $2 }
        }
    }
    return $tx;
}

sub req_ok {
    my ($method, $path, $body, $label) = @_;
    my $tx = do_req($method, $path, $body);
    my $code = $tx->res->code // 0;
    assert($code == 200, $label);
    return $tx;
}

sub req_accept {
    my ($method, $path, $body, $label) = @_;
    my $tx = do_req($method, $path, $body);
    my $code = $tx->res->code // 0;
    assert($code == 200 || $code == 204 || $code == 302, $label);
    return $tx;
}

sub body_from_button {
    my ($btn) = @_;
    my %body;
    my $attr = $btn->attr;
    if ($attr) {
        for my $name (keys %$attr) {
            next unless $name =~ /^data-/;
            (my $key = $name) =~ s/^data-//;
            $key =~ s/-([a-z])/\u$1/g;
            next if $key eq 'actionUrl' || $key eq 'method' || $key eq 'confirm' || $key eq 'redirect';
            $key =~ s/([A-Z])/_$1/g;
            $key = lc $key;
            $body{$key} = $attr->{$name};
        }
    }
    return \%body;
}

sub extract_csrf {
    my ($tx) = @_;
    my $json = eval { decode_json($tx->res->body) };
    if ($json && $json->{csrf_token}) {
        $CSRF = $json->{csrf_token};
    }
}

# ── Server start ──────────────────────────────────────────────────
my $tmpdir = tempdir(CLEANUP => 1);
my $data_dir = "$tmpdir/data";
my $cfg_file = "$tmpdir/config.yml";
mkdir $data_dir;

open my $cfh, '>', $cfg_file or die $!;
print $cfh <<'YAML';
secrets:
  - walkthrough-secret
market_counter_offers: 1
market_multi_item: 1
session_timeout_minutes: 1440
YAML
close $cfh;

my $pid = fork;
die "fork: $!" unless defined $pid;

if ($pid == 0) {
    $ENV{MM_DATA_DIR}  = $data_dir;
    $ENV{MM_CFG_FILE}  = $cfg_file;
    $ENV{MOJO_MODE}    = 'test';
    $ENV{MM_EVENTS}    = 1;
    $ENV{MM_RAND_SEED} = '42';
    exec "perl", "-I$ROOT/lib", "$ROOT/script/mountain", "daemon",
        "--listen", "http://127.0.0.1:$PORT";
    die "exec failed: $!";
}

END { kill 15, $pid if $pid; waitpid $pid, 0 if $pid }

# Wait for server
print STDERR "Waiting for server...";
my $ready;
for (1..30) {
    my $tx = eval { $ua->get("$BASE/health") };
    if ($tx && $tx->res && defined($tx->res->code) && $tx->res->code == 200) { $ready = 1; print STDERR " ready\n"; last }
    print STDERR ".";
    sleep 1;
}
print STDERR "\n";
die "Server did not start within 30 seconds" unless $ready;

# ══════════════════════════════════════════════════════════════════
# SCENE 1: Login
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Login ===\n";
my $tx = req_ok(POST => '/sessions', { displayName => 'walkthrough_user' }, 'POST /sessions');
extract_csrf($tx);

# ══════════════════════════════════════════════════════════════════
# SCENE 2: Game page
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Game page ===\n";
$tx = req_ok(GET => '/game', undef, 'GET /game');

# ══════════════════════════════════════════════════════════════════
# SCENE 3: Nav discovery — walk the available views
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Nav discovery ===\n";

sub click_tab {
    my ($tab_id) = @_;
    # Fetch fresh nav to get action_url from backend
    my $tx = do_req(GET => '/nav');
    assert($tx->res->code == 200, "nav before tab:$tab_id");
    my $nav = eval { decode_json($tx->res->body) };
    return unless $nav;
    my ($tab) = grep { $_->{id} eq $tab_id } @{ $nav->{primary_tabs} // [] };
    return unless $tab;
    if ($tab->{action_url}) {
        $tx = req_ok(POST => $tab->{action_url}, undef, "POST $tab->{action_url} (tab:$tab_id)");
        extract_csrf($tx);
        return;
    }
    # Navigate via /nav with X-Nav-View header
    $tx = $ua->build_tx(GET => "$BASE/nav");
    $tx->req->headers->header('X-Nav-View' => $tab_id);
    if (my @ck = map { "$_=$COOKIE{$_}" } keys %COOKIE) {
        $tx->req->headers->header(Cookie => join('; ', @ck));
    }
    $tx = $ua->start($tx);
    assert($tx->res->code == 200, "nav tab:$tab_id");
    my $sc = $tx->res->headers->set_cookie;
    if ($sc) {
        for my $c (ref $sc eq 'ARRAY' ? @$sc : ($sc)) {
            if ($c =~ /^([^=]+)=([^;]+)/) { $COOKIE{$1} = $2 }
        }
    }
}

sub fetch_nav {
    my $tx = do_req(GET => '/nav');
    return undef unless $tx->res->code == 200;
    my $nav = eval { decode_json($tx->res->body) };
    return $nav;
}

# Fetch initial nav to see idle tabs
my $nav = fetch_nav();
assert(defined $nav && $nav->{current_view} eq 'home', 'nav current_view home');
assert(defined $nav && ref $nav->{primary_tabs} eq 'ARRAY', 'nav has primary_tabs');

# Fetch all fragment endpoints (accept 200 or 204)
print STDERR "--- Fragment endpoints ---\n";
my @fragments = qw(/player?_format=fragment /crier?_format=fragment /home?_format=fragment /idle?_format=fragment
    /prospecting?_format=fragment /market?_format=fragment /shed?_format=fragment
    /skills?_format=fragment /factions?_format=fragment /leaderboard?_format=fragment
    /leaderboard/factions);
for my $ep (@fragments) {
    req_accept(GET => $ep, undef, "GET $ep");
}

# ══════════════════════════════════════════════════════════════════
# SCENE 4: Prospecting
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Prospecting ===\n";

# Begin prospecting — may fire events. Resolve events and continue
# until we have an artifact to push. After every continue() we check
# the prospecting fragment (not the JSON response, which is just
# {ok:1}) to see if another event fired.
my $collapsed;

$tx = req_ok(POST => '/prospecting/begin', undef, 'POST /prospecting/begin');
extract_csrf($tx);
my $json = eval { decode_json($tx->res->body) };
assert($json && $json->{ok}, 'begin response ok');

# Handle the first begin response (JSON carries event details)
if ($json->{result} && $json->{result} eq 'event') {
    print STDERR "  Choice event [$json->{event}{id}]\n";
    assert($json->{event}{choices} && @{ $json->{event}{choices} } > 0, 'choice event has choices');
    my $choice = $json->{event}{choices}[0];
    $tx = req_ok(POST => $choice->{attrs}{'data-action-url'},
        { choice_id => $choice->{id} }, 'POST /prospecting/resolve_event');
    extract_csrf($tx);
    $json = eval { decode_json($tx->res->body) };
    assert($json && $json->{ok} && $json->{result} eq 'event_choice', 'choice resolved to event_choice');
    $tx = req_ok(POST => '/result/continue', undef, 'POST /result/continue after choice event');
    extract_csrf($tx);
} elsif ($json->{event}) {
    print STDERR "  Passive event [$json->{event}{id}]\n";
    assert($json->{event}{id} =~ /^[a-z][a-z0-9_]*$/, 'event id valid');
    $tx = req_ok(POST => '/result/continue', undef, 'POST /result/continue after passive event');
    extract_csrf($tx);
} else {
    print STDERR "  No event fired (normal)\n";
}

# After every continue, check the fragment for events.
# Loop until we have an artifact (push/stop buttons visible)
# or exhaust the guard (all events, no artifact possible).
my $EVENT_GUARD = 6;
my $got_artifact;
for (1 .. $EVENT_GUARD) {
    my $frag = do_req(GET => '/prospecting?_format=fragment');
    my $code = $frag->res->code // 0;

    # 204 = no pending activity (passive event consumed it)
    if ($code == 204) {
        print STDERR "  Passive event after continue\n";
        my $cont = do_req(POST => '/result/continue');
        last unless $cont->res->code == 200;
        extract_csrf($cont);
        next;
    }

    my $frag_dom = Mojo::DOM->new($frag->res->body);
    my $event_btn = $frag_dom->at('button[data-action-url="/prospecting/resolve_event"]');
    if ($event_btn) {
        print STDERR "  Choice event after continue\n";
        my $body = body_from_button($event_btn);
        do_req(POST => '/prospecting/resolve_event', $body);
        my $cont = do_req(POST => '/result/continue');
        last unless $cont->res->code == 200;
        extract_csrf($cont);
        next;
    }

    # No event — should see push/stop buttons (artifact ready)
    $got_artifact = 1;
    last;
}

# Check for push/stop buttons to confirm we have an artifact
my $frag_check = do_req(GET => '/prospecting?_format=fragment');
if ($got_artifact && $frag_check->res->code == 200) {
    my $check_dom = Mojo::DOM->new($frag_check->res->body);
    $got_artifact = $check_dom->at('button[data-action-url="/prospecting/push"]') ? 1 : 0;
}

unless ($got_artifact) {
    print STDERR "  No artifact after events — skipping push/stop\n";
    $PASS++;
    $collapsed = 1;
    goto AFTER_PROSPECTING;
}

# Should see prospecting fragment with action buttons
my $frag = do_req(GET => '/prospecting?_format=fragment');
assert($frag->res->code == 200, 'GET /prospecting?_format=fragment (active)');
my $dom = Mojo::DOM->new($frag->res->body);

# Find action buttons (Push, Stop) or choice buttons
my @actions = map { +{ url => $_->attr('data-action-url'), method => $_->attr('data-method') } }
    $dom->find('button[data-action-url]')->each;
assert(scalar @actions >= 1, 'prospecting fragment has action or choice buttons');

# Push — check each response; collapse/breakthrough ends the loop early
for my $i (1..2) {
    my $resp = do_req(POST => '/prospecting/push');
    my $code = $resp->res->code // 0;
    if ($code != 200) {
        print STDERR "  Push $i failed (HTTP $code) — prospecting ended\n";
        $collapsed = 1;
        last;
    }
    extract_csrf($resp);
    $PASS++;
    my $push_json = eval { decode_json($resp->res->body) };
    my $result = $push_json->{result} // '';
    if ($result eq 'collapse') {
        print STDERR "  Artifact collapsed on push $i — prospecting ended\n";
        $collapsed = 1;
        last;
    }
    if ($result eq 'breakthrough') {
        print STDERR "  Breakthrough on push $i — artifact auto-sold, prospecting ended\n";
        $collapsed = 1;
        last;
    }
}

# Stop — only if the artifact survived
if (!$collapsed) {
    $tx = req_ok(POST => '/prospecting/stop', undef, 'POST /prospecting/stop');
    extract_csrf($tx);
} else {
    print STDERR "  Skipping stop (collapsed)\n";
    $PASS++;
}

AFTER_PROSPECTING:

# ══════════════════════════════════════════════════════════════════
# SCENE 5: Market Visit
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Market Visit ===\n";

eval { click_tab('bazaar') };
if ($@) {
    print STDERR "  Could not enter market (may have no shed items)\n";
    $PASS += 3;  # skip market, shed, and offer
    goto AFTER_MARKET;
}

# Market fragment (204 = no active visit, e.g. no shed items)
my $market = do_req(GET => '/market?_format=fragment');
assert($market->res->code == 200 || $market->res->code == 204, 'GET /market?_format=fragment (active)');

# Check shed for items during market (Offer buttons only visible when market_active=1)
my $shed = do_req(GET => '/shed?_format=fragment');
assert($shed->res->code == 200, 'GET /shed?_format=fragment (during market)');
$dom = Mojo::DOM->new($shed->res->body);
my @offer_btns = $dom->find('button[data-action-url="/market/offer"]')->each;
my $offer_body;
if (@offer_btns) {
    $offer_body = body_from_button($offer_btns[0]);
    print STDERR "  Offer body: " . (encode_json($offer_body)) . "\n";
} else {
    print STDERR "  No shed items for offer (may have collapsed)\n";
    $PASS++;
}

# Offer item if available
if ($offer_body) {
    $tx = req_ok(POST => '/market/offer', $offer_body, 'POST /market/offer');
    extract_csrf($tx);
}

# Send away (may fail if market visit already ended via sale/breakthrough)
$tx = do_req(POST => '/market/send_away');
if ($tx->res->code == 200) {
    extract_csrf($tx);
    $PASS++;
    print STDERR "  Market visit ended (send_away)\n";
} else {
    print STDERR "  Market visit already ended (sale/resolved) — ok\n";
    $PASS++;
}

AFTER_MARKET:

# ══════════════════════════════════════════════════════════════════
# SCENE 7: Skills
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Skills ===\n";

my $skills = do_req(GET => '/skills?_format=fragment');
assert($skills->res->code == 200, 'GET /skills?_format=fragment');

$dom = Mojo::DOM->new($skills->res->body);
my @skill_btns = $dom->find('button[data-action-url="/skills/purchase"]:not([disabled])')->each;
if (@skill_btns) {
    my $body = body_from_button($skill_btns[0]);
    my $tx = req_ok(POST => '/skills/purchase', $body, "POST /skills/purchase");
    extract_csrf($tx);
} else {
    print STDERR "  No purchasable skills (insufficient scrap)\n";
    $PASS++;
}

# ══════════════════════════════════════════════════════════════════
# SCENE 8: Nav check
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Nav final check ===\n";
$nav = fetch_nav();
assert(defined $nav && ref $nav->{primary_tabs} eq 'ARRAY', 'nav returns primary_tabs after all actions');

# ══════════════════════════════════════════════════════════════════
# SCENE 9: Logout
# ══════════════════════════════════════════════════════════════════
print STDERR "=== SCENE: Logout ===\n";
req_ok(DELETE => '/sessions', undef, 'DELETE /sessions');
req_ok(GET => '/game', undef, 'GET /game (after logout, unauthenticated)');

# ══════════════════════════════════════════════════════════════════
# Report
# ══════════════════════════════════════════════════════════════════
print STDERR "---\n";
print STDERR "RESULTS: $PASS passed, $FAIL failed\n";
exit $FAIL ? 1 : 0;
