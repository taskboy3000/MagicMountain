<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrf_token %>">
    <title>ProspectBoy 3000</title>
    <link rel="icon" type="image/svg+xml" href="<%= url_for('/images/favicon.svg') %>">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css">
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="<%= url_for('/css/app.css') %>?<%= (stat app->home->child('public/css/app.css'))[9] // 0 %>">
  </head>
  <body data-game-url="<%= url_for('game') %>">
    <div id="page-wrap">
      <%= content %>
    </div>
    <footer id="page-footer">
      <a href="https://github.com/taskboy3000/MagicMountain" style="color:inherit;text-decoration:none;border-bottom:1px dotted rgba(255,255,255,0.15)" target="_blank" rel="noopener">ProspectBoy 3000 on GitHub</a>
    </footer>
% unless (current_player) {
<script src="<%= url_for('/js/ambient.js') %>?<%= (stat app->home->child('public/js/ambient.js'))[9] // 0 %>"></script>
<script src="<%= url_for('/js/app.js') %>?<%= (stat app->home->child('public/js/app.js'))[9] // 0 %>"></script>
% }
  </body>
</html>