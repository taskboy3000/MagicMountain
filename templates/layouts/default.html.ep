<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrf_token %>">
    <title>Magic Mountain</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css">
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/app.css?<%= (stat app->home->child('public/css/app.css'))[9] // 0 %>">
  </head>
  <body>
    <div id="page-wrap">
      <%= content %>
    </div>
    <footer id="page-footer">
      <a href="https://github.com/taskboy3000/MagicMountain" style="color:inherit;text-decoration:none;border-bottom:1px dotted rgba(255,255,255,0.15)" target="_blank" rel="noopener">Magic Mountain on GitHub</a>
    </footer>
% unless (current_player) {
<script>
let _pendingDisplayName = '';
const panel = document.getElementById('panel-primary');

async function showTokenPrompt() {
  const resp = await fetch(`/sessions/token-prompt?display_name=${encodeURIComponent(_pendingDisplayName)}&_format=fragment`);
  panel.innerHTML = await resp.text();
  panel.querySelector('#token-form')?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const tokenInput = document.getElementById('token-input');
    const errEl = document.getElementById('token-error');
    const token = tokenInput ? tokenInput.value.trim() : '';
    if (!token) return;
    const resp = await fetch('/sessions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ displayName: _pendingDisplayName, token })
    });
    const data = await resp.json();
    if (!data.ok) {
      errEl.textContent = data.error || 'Invalid token';
      errEl.style.display = 'block';
      return;
    }
    window.location.href = '/game';
  });
}

async function showRecoveryForm() {
  const resp = await fetch(`/sessions/recovery-form?display_name=${encodeURIComponent(_pendingDisplayName)}&_format=fragment`);
  panel.innerHTML = await resp.text();
  panel.querySelector('#recovery-form')?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const input = document.getElementById('recovery-input');
    const errEl = document.getElementById('recovery-error');
    const code = input ? input.value.trim() : '';
    if (!code) return;
    const resp = await fetch('/sessions/recover', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ displayName: _pendingDisplayName, recoveryCode: code })
    });
    const data = await resp.json();
    if (!data.ok) {
      errEl.textContent = data.error || 'Invalid recovery code';
      errEl.style.display = 'block';
      return;
    }
    showCredentials();
  });
}

async function showCredentials() {
  const resp = await fetch('/sessions/credentials?_format=fragment');
  if (resp.status === 204) { window.location.href = '/game'; return; }
  panel.innerHTML = await resp.text();
}

panel.addEventListener('click', (ev) => {
  if (ev.target.id === 'forgot-token-link') showRecoveryForm();
  if (ev.target.id === 'back-to-token-link') showTokenPrompt();
  if (ev.target.id === 'continue-btn') window.location.href = '/game';
});

document.getElementById('login-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const nameInput = document.getElementById('display-name');
  const name = nameInput ? nameInput.value.trim() : '';
  const errEl = document.getElementById('error-msg');
  errEl.style.display = 'none';
  if (!name && !_pendingDisplayName) return;
  const body = { displayName: _pendingDisplayName || name };
  const resp = await fetch('/sessions', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  });
  const data = await resp.json();
  if (!data.ok) {
    if (data.need_token) {
      _pendingDisplayName = data.display_name;
      showTokenPrompt();
      return;
    }
    errEl.textContent = data.error || 'Login failed';
    errEl.style.display = 'block';
    return;
  }
  _pendingDisplayName = '';
  if (data.show_credentials) {
    showCredentials();
    return;
  }
  window.location.href = '/game';
});
</script>
% }
  </body>
</html>