<div class="mm-panel">
  <div class="mm-panel-header">
% if (my $url = $entry->{icon}) {
    <img src="<%= $url %>" alt="" class="mm-icon" style="vertical-align:middle;margin-right:4px">
% }
    <%= $entry->{title} %>
    <span class="mm-text-dim"> — <%= $entry->{subtitle} %></span>
  </div>
  <div class="mm-panel-body">
% for my $line (@{ $entry->{body} }) {
    <p style="margin:0 0 0.5rem 0;font-size:0.78rem;line-height:1.6"><%= $line %></p>
% }
  </div>
</div>
