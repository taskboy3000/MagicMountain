<div class="mm-panel">
  <h2 class="mm-panel-header">
% if (my $url = $entry->{icon}) {
    <img src="<%= $url %>" alt="" class="mm-icon" style="margin-right:4px">
% }
    <%= $entry->{title} %>
    <span class="mm-text-dim"> — <%= $entry->{subtitle} %></span>
  </div>
  <div class="mm-panel-body">
% for my $line (@{ $entry->{body} }) {
    <p class="mm-text-sm mm-mb-sm" style="line-height:1.6"><%= $line %></p>
% }
  </div>
</div>
