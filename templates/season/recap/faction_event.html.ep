% my @alliance = (sprintf('FIELD INTELLIGENCE: <strong>%s</strong> and <strong>%s</strong> entered a temporary procurement alliance during the season\'s midpoint. The arrangement dissolved without formal agreement.', $faction_a, $faction_b), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> extended a formal cooperation offer to <strong>%s</strong>. Terms were not disclosed. Outcome: inconclusive.', $faction_a, $faction_b), sprintf('FIELD INTELLIGENCE: Unconfirmed reports indicate <strong>%s</strong> and <strong>%s</strong> shared logistics data for a period of approximately 6 days. Mutual benefit unverified.', $faction_a, $faction_b));
% my @war = (sprintf('FIELD INTELLIGENCE: <strong>%s</strong> issued a procurement sanction against <strong>%s</strong>, citing unfair acquisition practices. No measurable impact on either party\'s market access.', $faction_a, $faction_b), sprintf('FIELD INTELLIGENCE: Hostility between <strong>%s</strong> and <strong>%s</strong> escalated to open competition on three separate artifact categories. Both sides sustained elevated acquisition costs.', $faction_a, $faction_b), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> accused <strong>%s</strong> of contract interference. <strong>%s</strong> denied all claims. The Bazaar council declined to intervene.', $faction_a, $faction_b, $faction_b));
% my @frustration = (sprintf('FIELD INTELLIGENCE: <strong>%s</strong> buyer agents expressed frustration with artifact quality this season. Internal memos describe the local supply as \'inconsistent.\'', $faction_a), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> procurement targets were not met. Internal review cites \'insufficient throughput from local extractors.\'', $faction_a), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> representatives were overheard criticizing the pace of artifact recovery. Word from their compound: they need more, faster.', $faction_a));
% my @merger = (sprintf('FIELD INTELLIGENCE: <strong>%s</strong> absorbed a smaller operational unit mid-season. The acquisition did not significantly alter their market footprint.', $faction_a), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> acquired supply lines previously controlled by a defunct operator. The move was interpreted as consolidation.', $faction_a), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> consolidated two satellite procurement offices into their main operation. Efficiency gains were marginal.', $faction_a));
% my @stalemate = (sprintf('FIELD INTELLIGENCE: A dispute between <strong>%s</strong> and <strong>%s</strong> over territorial extraction rights reached a stalemate. Neither party yielded.', $faction_a, $faction_b), sprintf('FIELD INTELLIGENCE: <strong>%s</strong> and <strong>%s</strong> remain deadlocked over outstanding procurement obligations. Settlement expected next season.', $faction_a, $faction_b), sprintf('FIELD INTELLIGENCE: Negotiations between <strong>%s</strong> and <strong>%s</strong> collapsed. Both parties returned to independent procurement strategies.', $faction_a, $faction_b));
% my %texts = (alliance => \@alliance, war => \@war, frustration => \@frustration, merger => \@merger, stalemate => \@stalemate);
% my $lines = $texts{$variant} or return;
<%= $lines->[rand @$lines] %>
